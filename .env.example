# ── AI ────────────────────────────────────────────────────────────────────────
NVIDIA_API_KEY=your_nvidia_key_here

# ── TMDB (movies & TV shows) ──────────────────────────────────────────────────
# Get your free Read Access Token at: https://www.themoviedb.org/settings/api
# Use the long eyJ... token, NOT the short v3 key
TMDB_API_KEY=your_tmdb_read_access_token_here

# ── MySQL database ────────────────────────────────────────────────────────────
MYSQLHOST=localhost
MYSQLPORT=3306
MYSQLUSER=root
MYSQLPASSWORD=
MYSQLDATABASE=recommender_db

# ── Access lock ───────────────────────────────────────────────────────────────
# Password users must enter after 4 free messages
UNLOCK_PASSWORD=your_password_here
GA_MEASUREMENT_ID=G-XXXXXXXXXX

# ── Aiven (production only) ───────────────────────────────────────────────────
# Set these when deploying to Render + Aiven MySQL
# MYSQLHOST=your-service.aivencloud.com
# MYSQLPORT=12345
# MYSQLUSER=avnadmin
# MYSQLPASSWORD=your_aiven_password
# MYSQLDATABASE=defaultdb
# MYSQL_SSL=true
# MYSQL_SSL_CA=ca.pem
